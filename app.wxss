page { background: #0a0a1a; color: #fff; font-family: -apple-system, sans-serif; }
.btn-primary { background: linear-gradient(135deg, #ff6b9d, #c44dff); color: #fff; border-radius: 16rpx; padding: 24rpx 0; text-align: center; font-size: 32rpx; font-weight: bold; border: none; }
.btn-primary::after { border: none; }
.btn-secondary { background: rgba(255,107,157,0.15); color: #ff6b9d; border-radius: 16rpx; padding: 24rpx 0; text-align: center; font-size: 32rpx; border: 2rpx solid rgba(255,107,157,0.3); }
.card { background: rgba(255,255,255,0.06); border-radius: 24rpx; padding: 32rpx; margin-bottom: 24rpx; border: 1rpx solid rgba(255,255,255,0.08); }
