/* ========== 全局 ========== */
.nav-bar{position:fixed;top:0;left:0;right:0;height:88rpx;display:flex;align-items:center;padding:0 30rpx;z-index:100}
.nav-back{color:#fff;font-size:32rpx;padding:10rpx}
.nav-title{flex:1;text-align:center;color:#fff;font-size:36rpx;font-weight:bold}
.nav-right{width:60rpx}
.game-area{padding:100rpx 30rpx 40rpx;min-height:100vh;background:linear-gradient(180deg,#1a1a2e 0%,#16213e 50%,#0f3460 100%)}

/* ========== 玩家栏 ========== */
.player-bar{position:fixed;top:88rpx;left:0;right:0;z-index:99;background:rgba(0,0,0,0.6);padding:16rpx 20rpx;display:flex;align-items:center}
.player-scroll{flex:1;white-space:nowrap}
.player-chip{display:inline-flex;align-items:center;gap:8rpx;padding:12rpx 24rpx;border-radius:40rpx;color:#fff;font-size:26rpx;margin-right:12rpx;border:2rpx solid rgba(255,255,255,0.2)}
.chip-name{max-width:120rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

/* ========== 结果卡片 ========== */
.result-card{background:rgba(255,255,255,0.08);border-radius:24rpx;padding:40rpx;margin-top:30rpx;border:2rpx solid rgba(255,255,255,0.1);text-align:center}
.result-who{font-size:30rpx;color:#ffd700;font-weight:bold;margin-bottom:12rpx}
.result-label{font-size:36rpx;font-weight:bold;color:#fff;margin-bottom:16rpx}
.result-content{font-size:34rpx;color:rgba(255,255,255,0.9);line-height:1.6;margin-bottom:20rpx}

/* ========== 通用按钮 ========== */
.spin-btn{padding:24rpx 0;border-radius:50rpx;color:#fff;font-size:32rpx;font-weight:bold;text-align:center;margin:20rpx auto;width:80%;max-width:500rpx}
.spin-btn:active{opacity:0.8;transform:scale(0.97)}

/* ========== 转盘（clip-path 扇形） ========== */
.roulette-wrap{position:relative;width:600rpx;height:600rpx;margin:30rpx auto}
.roulette-wrap.big{width:680rpx;height:680rpx}
.roulette-pointer{position:absolute;top:-14rpx;left:50%;transform:translateX(-50%);font-size:52rpx;color:#ffd700;z-index:10;text-shadow:0 0 16px rgba(255,215,0,0.9)}
.roulette{position:absolute;width:100%;height:100%;border-radius:50%;transition:transform 4.5s cubic-bezier(0.17,0.67,0.12,0.99);border:6rpx solid rgba(255,255,255,0.3);box-shadow:0 0 40rpx rgba(255,107,157,0.4)}
.seg{position:absolute;width:100%;height:100%;top:0;left:0;display:flex;align-items:center;justify-content:center}
.seg-text{color:#fff;font-size:22rpx;font-weight:bold;text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:240rpx;position:absolute;top:10%;left:50%;transform-origin:50% 260rpx}
.rw-seg .rw-text{font-size:16rpx;max-width:180rpx}

/* ========== 骰子 ========== */
.dice-box{display:flex;flex-direction:column;align-items:center;padding:60rpx 0}
.dice{width:200rpx;height:200rpx;background:#fff;border-radius:24rpx;display:flex;align-items:center;justify-content:center;box-shadow:0 8rpx 32rpx rgba(0,0,0,0.3);cursor:pointer}
.dice:active{transform:scale(0.95)}
.dice-spin{animation:diceShake 0.8s ease-in-out}
@keyframes diceShake{0%{transform:rotate(0deg) scale(1)}25%{transform:rotate(20deg) scale(1.1)}50%{transform:rotate(-15deg) scale(0.95)}75%{transform:rotate(10deg) scale(1.05)}100%{transform:rotate(0deg) scale(1)}}
.dice-num{font-size:80rpx;color:#1a1a2e;font-weight:bold}
.dice-label{font-size:28rpx;color:rgba(255,255,255,0.6);margin-top:20rpx}
.dice-target{font-size:28rpx;color:#ffd700;margin-top:12rpx}

/* ========== 国王 ========== */
.king-info{color:rgba(255,255,255,0.6);font-size:28rpx;text-align:center;padding:20rpx 0}
.king-cards{display:flex;flex-wrap:wrap;justify-content:center;gap:16rpx;padding:20rpx 0}
.king-card{width:100rpx;height:140rpx;perspective:600rpx}
.king-card-inner{width:100%;height:100%;transition:transform 0.6s;transform-style:preserve-3d;position:relative}
.king-card.revealed .king-card-inner{transform:rotateY(180deg)}
.king-front,.king-back{position:absolute;width:100%;height:100%;backface-visibility:hidden;display:flex;align-items:center;justify-content:center;border-radius:12rpx;font-size:36rpx}
.king-front{background:linear-gradient(135deg,#eab308,#f59e0b);color:#fff}
.king-back{background:linear-gradient(135deg,#334155,#475569);color:#fff;transform:rotateY(180deg);font-size:24rpx}

/* ========== 传纸巾 ========== */
.tissue-scene{display:flex;align-items:center;justify-content:center;gap:40rpx;padding:60rpx 0}
.person{font-size:64rpx}
.tissue-area{display:flex;align-items:center;justify-content:center;min-width:120rpx}
.tissue{background:rgba(255,255,255,0.8);border-radius:8rpx;transition:all 0.3s}
.tissue-info{text-align:center;color:rgba(255,255,255,0.7);font-size:26rpx;padding:20rpx 0}
.tissue-bar{width:80%;height:12rpx;background:rgba(255,255,255,0.1);border-radius:6rpx;margin:12rpx auto;overflow:hidden}
.tissue-fill{height:100%;background:linear-gradient(90deg,#fb923c,#f97316);border-radius:6rpx;transition:width 0.3s}

/* ========== 蒙眼 ========== */
.blindfold{text-align:center;padding:40rpx 0}
.blindfold-icon{font-size:80rpx}
.blindfold-text{font-size:32rpx;color:#fff;margin:12rpx 0}
.blindfold-score{font-size:28rpx;color:#d946ef;font-weight:bold}
.blindfold-target{font-size:24rpx;color:rgba(255,255,255,0.5);margin-top:8rpx}
.body-grid{display:flex;flex-wrap:wrap;justify-content:center;gap:20rpx;padding:20rpx 0}
.body-btn{padding:20rpx 32rpx;background:rgba(217,70,239,0.15);border:2rpx solid rgba(217,70,239,0.3);border-radius:16rpx;color:#fff;font-size:28rpx}
.body-btn:active{background:rgba(217,70,239,0.4)}

/* ========== 你比我猜 ========== */
.gw-header{display:flex;justify-content:space-between;align-items:center;padding:20rpx 0}
.gw-timer{font-size:64rpx;font-weight:bold}
.gw-score{font-size:28rpx;color:rgba(255,255,255,0.7)}
.gw-card{text-align:center;padding:60rpx 0}
.gw-word{font-size:56rpx;font-weight:bold;color:#c084fc;margin-bottom:20rpx}
.gw-hint{font-size:24rpx;color:rgba(255,255,255,0.5);margin-bottom:40rpx}
.gw-btns{display:flex;justify-content:center;gap:24rpx}
.gw-btn{padding:20rpx 40rpx;border-radius:16rpx;color:#fff;font-size:28rpx;font-weight:bold}
.gw-btn.pass{background:rgba(255,255,255,0.15)}
.gw-btn.start{background:#8b5cf6}
.gw-btn.correct{background:#22c55e}

/* ========== 石头剪刀布 ========== */
.rps-area{display:flex;align-items:center;justify-content:center;gap:40rpx;padding:60rpx 0}
.rps-players{display:flex;flex-direction:column;align-items:center;gap:16rpx}
.rps-label{font-size:28rpx;color:rgba(255,255,255,0.7)}
.rps-emoji{font-size:80rpx}
.rps-vs{font-size:48rpx;font-weight:bold;color:#f43f5e}
.rps-btns{display:flex;justify-content:center;gap:32rpx;padding:20rpx 0}
.rps-btn{width:120rpx;height:120rpx;display:flex;align-items:center;justify-content:center;font-size:56rpx;background:rgba(255,255,255,0.1);border-radius:50%}
.rps-btn:active{background:rgba(255,255,255,0.25);transform:scale(0.9)}

/* ========== 心跳告白 ========== */
.hb-stages{display:flex;justify-content:center;gap:12rpx;padding:20rpx 0}
.hb-stage{padding:12rpx 20rpx;border-radius:20rpx;font-size:24rpx;color:rgba(255,255,255,0.4);background:rgba(255,255,255,0.05)}
.hb-stage.active{color:#fff;background:rgba(236,72,153,0.3);border:1rpx solid rgba(236,72,153,0.5)}
.hb-content{text-align:center;padding:40rpx 0}
.hb-stage-name{font-size:40rpx;font-weight:bold;margin-bottom:16rpx}
.hb-desc{font-size:28rpx;color:rgba(255,255,255,0.6);margin-bottom:24rpx}
.hb-timer{font-size:72rpx;font-weight:bold;color:#ec4899;margin:20rpx 0}
.hb-question{font-size:30rpx;color:#ffd700;padding:20rpx;background:rgba(255,215,0,0.1);border-radius:16rpx;margin:20rpx auto;width:80%}

/* ========== 惩罚转盘 ========== */
.rw-seg .rw-text{font-size:14rpx}

/* ========== 悄悄话 ========== */
.whisper-scene{text-align:center;padding:80rpx 0}
.whisper-text{font-size:30rpx;color:rgba(255,255,255,0.6)}
.whisper-card{background:rgba(244,114,182,0.15);border:2rpx solid rgba(244,114,182,0.3);border-radius:24rpx;padding:48rpx;margin:20rpx auto;width:80%}
.whisper-emoji{font-size:80rpx}
.whisper-content{font-size:34rpx;color:#fff;margin:24rpx 0;line-height:1.8}
.whisper-hide{color:#f472b6;font-size:28rpx;margin-top:20rpx}


/* ========== 单人模式游戏选择列表 ========== */
.solo-game-list{padding:20rpx 30rpx 120rpx}
.solo-list-title{text-align:center;font-size:36rpx;color:#ffd700;font-weight:bold;padding:40rpx 0 30rpx}
.solo-game-card{display:flex;align-items:center;background:rgba(255,255,255,0.06);border:2rpx solid rgba(255,255,255,0.1);border-radius:24rpx;padding:28rpx 24rpx;margin-bottom:20rpx;transition:all 0.2s}
.solo-game-card:active{transform:scale(0.97);border-color:#ff6b9d}
.solo-game-icon{font-size:56rpx;margin-right:24rpx;flex-shrink:0}
.solo-game-info{flex:1;display:flex;flex-direction:column}
.solo-game-name{font-size:30rpx;color:#fff;font-weight:bold}
.solo-game-desc{font-size:22rpx;color:rgba(255,255,255,0.6);margin-top:8rpx}

/* 返回按钮 */
.back-btn{padding:20rpx 30rpx;color:#ff6b9d;font-size:28rpx}
.back-btn:active{opacity:0.7}

/* 游戏标题 */
.game-header{text-align:center;padding:20rpx 0}
.game-title{color:#fff;font-size:32rpx;font-weight:bold}
