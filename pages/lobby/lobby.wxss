.page { padding: 20rpx 30rpx 200rpx; }
.room-header { text-align: center; padding: 40rpx 0; }
.room-label { display: block; font-size: 24rpx; color: rgba(255,255,255,0.5); }
.room-code { display: block; font-size: 80rpx; font-weight: bold; color: #ff6b9d; letter-spacing: 16rpx; margin: 12rpx 0; font-family: monospace; }
.room-tip { display: block; font-size: 24rpx; color: rgba(255,255,255,0.4); }
.share-btn { display: flex; align-items: center; justify-content: center; gap: 16rpx; background: linear-gradient(135deg, #07c160, #06ad56); border-radius: 16rpx; padding: 28rpx; margin-bottom: 40rpx; }
.share-icon { font-size: 36rpx; }
.share-text { font-size: 30rpx; color: #fff; font-weight: bold; }
.players-section { margin-bottom: 40rpx; }
.players-title { display: block; font-size: 28rpx; font-weight: bold; margin-bottom: 20rpx; }
.players-grid { display: flex; flex-wrap: wrap; gap: 20rpx; }
.player-card { width: calc(33.3% - 14rpx); display: flex; flex-direction: column; align-items: center; padding: 28rpx 0; background: rgba(255,255,255,0.06); border-radius: 20rpx; position: relative; }
.player-card.empty { border: 2rpx dashed rgba(255,255,255,0.15); background: transparent; }
.player-avatar { font-size: 48rpx; }
.empty-avatar { color: rgba(255,255,255,0.2); font-size: 40rpx; }
.player-name { font-size: 24rpx; margin-top: 8rpx; max-width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.empty-name { color: rgba(255,255,255,0.2); }
.player-gender { font-size: 22rpx; color: rgba(255,255,255,0.4); margin-top: 4rpx; }
.player-host { position: absolute; top: -8rpx; right: -8rpx; background: linear-gradient(135deg, #ff6b9d, #c44dff); color: #fff; font-size: 18rpx; padding: 4rpx 12rpx; border-radius: 12rpx; }
.wait-tip { text-align: center; color: rgba(255,255,255,0.4); font-size: 26rpx; padding: 30rpx 0; }
.game-select { margin-bottom: 20rpx; }
.select-title { display: block; font-size: 28rpx; font-weight: bold; margin-bottom: 20rpx; }
.game-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.game-opt { display: flex; align-items: center; gap: 12rpx; padding: 16rpx 24rpx; background: rgba(255,255,255,0.06); border-radius: 16rpx; border: 2rpx solid transparent; font-size: 26rpx; }
.game-opt.active { border-color: #ff6b9d; background: rgba(255,107,157,0.15); }
.game-opt-icon { font-size: 32rpx; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; padding: 24rpx 40rpx; padding-bottom: calc(24rpx + env(safe-area-inset-bottom)); background: rgba(10,10,26,0.95); backdrop-filter: blur(20px); }
.start-btn { width: 100%; height: 96rpx; line-height: 96rpx; }
.start-btn[disabled] { opacity: 0.4; }
.wait-bar { text-align: center; color: rgba(255,255,255,0.4); font-size: 28rpx; padding: 24rpx 0; }
