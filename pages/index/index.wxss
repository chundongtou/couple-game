.page { padding: 20rpx 30rpx 60rpx; }
.header { padding: 30rpx 0 40rpx; }
.header-user { display: flex; align-items: center; gap: 20rpx; }
.header-avatar { font-size: 60rpx; width: 80rpx; height: 80rpx; display: flex; align-items: center; justify-content: center; background: rgba(255,107,157,0.15); border-radius: 50%; }
.header-info { display: flex; flex-direction: column; }
.header-name { font-size: 34rpx; font-weight: bold; }
.header-gender { font-size: 24rpx; color: rgba(255,255,255,0.5); margin-top: 4rpx; }

/* 单人模式卡片 */
.solo-card { display: flex; align-items: center; background: linear-gradient(135deg, rgba(78,205,196,0.25), rgba(45,200,130,0.2)); border-radius: 24rpx; padding: 36rpx; margin-bottom: 20rpx; border: 2rpx solid rgba(78,205,196,0.4); }
.solo-icon { font-size: 50rpx; margin-right: 24rpx; }
.solo-text { flex: 1; display: flex; flex-direction: column; }
.solo-title { font-size: 32rpx; font-weight: bold; color: #4ecdc4; }
.solo-desc { font-size: 24rpx; color: rgba(255,255,255,0.5); margin-top: 6rpx; }
.solo-arrow { font-size: 48rpx; color: rgba(255,255,255,0.4); }

/* 创建房间 */
.action-card { display: flex; align-items: center; background: linear-gradient(135deg, rgba(255,107,157,0.2), rgba(196,77,255,0.2)); border-radius: 24rpx; padding: 36rpx; margin-bottom: 24rpx; border: 2rpx solid rgba(255,107,157,0.3); }
.action-icon { font-size: 50rpx; margin-right: 24rpx; }
.action-text { flex: 1; display: flex; flex-direction: column; }
.action-title { font-size: 32rpx; font-weight: bold; }
.action-desc { font-size: 24rpx; color: rgba(255,255,255,0.5); margin-top: 6rpx; }
.action-arrow { font-size: 48rpx; color: rgba(255,255,255,0.4); }

/* 加入房间 */
.join-card { padding: 32rpx; }
.join-title { font-size: 28rpx; color: rgba(255,255,255,0.7); display: block; margin-bottom: 20rpx; }
.join-row { display: flex; gap: 16rpx; }
.join-input { flex: 1; background: rgba(255,255,255,0.08); border-radius: 16rpx; padding: 20rpx; font-size: 36rpx; text-align: center; letter-spacing: 16rpx; color: #fff; border: 2rpx solid rgba(255,255,255,0.1); }
.join-btn { width: 200rpx !important; height: 80rpx !important; line-height: 80rpx !important; padding: 0 !important; font-size: 28rpx !important; }

/* 区块 */
.section { margin-top: 40rpx; }
.section-title { display: block; font-size: 30rpx; font-weight: bold; margin-bottom: 20rpx; }

/* 房间列表（带删除按钮） */
.room-item { display: flex; align-items: center; padding: 0 !important; }
.room-main { flex: 1; display: flex; justify-content: space-between; align-items: center; padding: 24rpx; }
.room-left { display: flex; flex-direction: column; }
.room-code { font-size: 36rpx; font-weight: bold; color: #ff6b9d; letter-spacing: 8rpx; }
.room-host { font-size: 24rpx; color: rgba(255,255,255,0.5); margin-top: 8rpx; }
.room-right { display: flex; flex-direction: column; align-items: flex-end; }
.room-players { font-size: 26rpx; }
.room-status { font-size: 22rpx; color: #4ecdc4; margin-top: 6rpx; }
.room-status.playing { color: #ff6b9d; }
.room-delete { width: 80rpx; display: flex; align-items: center; justify-content: center; padding: 24rpx 0; border-left: 2rpx solid rgba(255,255,255,0.06); }
.delete-icon { font-size: 32rpx; opacity: 0.5; }

/* 游戏列表 */
.game-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.game-item { width: calc(25% - 12rpx); display: flex; flex-direction: column; align-items: center; padding: 20rpx 0; background: rgba(255,255,255,0.04); border-radius: 16rpx; }
.game-item-icon { font-size: 36rpx; }
.game-item-name { font-size: 20rpx; color: rgba(255,255,255,0.6); margin-top: 8rpx; }
